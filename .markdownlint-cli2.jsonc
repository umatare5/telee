{
  "config": {
    "default": true,
    "first-line-h1": false,
    "header-increment": false,
    "line_length": false,
    "no-alt-text": false,
    "no-bare-urls": false,
    "no-blanks-blockquote": false,
    "no-duplicate-heading": false,
    "no-inline-html": false,
    "no-trailing-punctuation": false,
  },
  "ignores": [
    "vendor/**",
    ".github/instructions/**",
    ".github/copilot-instructions.md",
    ".claude/CLAUDE.md",
    ".gemini/GEMINI.md",
  ],
  "globs": ["**/*.md"],
}
